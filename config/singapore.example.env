# Singapore weather-model node example configuration.
# Copy to the deployment environment and fill private authorization values there.

# Open-Meteo runtime image. Copy the exact native-* tag printed by
# scripts/build_openmeteo_image.sh. Production never falls back to latest.
WEATHER_OPENMETEO_IMAGE=weather-forecast-openmeteo
WEATHER_OPENMETEO_TAG=native-REPLACE_WITH_PRINTED_SOURCE_ID
# Leave CPU and I/O headroom for the client-facing Rust API while Swift imports
# run. These are runtime resource controls, not disk-space admission limits.
# The current Singapore host has 2 vCPUs. Keep at least half a CPU plus the
# higher-priority scheduler share available to the client-facing API.
WEATHER_OPENMETEO_CPU_LIMIT=1.5
WEATHER_OPENMETEO_CPU_SHARES=256
WEATHER_OPENMETEO_BLKIO_WEIGHT=100
WEATHER_OM_WEBP_BIN=/opt/1panel/apps/weather_om_webp/bin/om-webp
WEATHER_OM_WEBP_DATA_ROOT=/opt/1panel/apps/weather_om_webp/data
WEATHER_OM_WEBP_PUBLIC_ROOT=/opt/1panel/apps/weather/data
WEATHER_OM_WEBP_WORKERS=1
WEATHER_OMFILE_LIB=/opt/1panel/apps/weather_om_api/native/libomfileformat.so
WEATHER_OM_API_SERVICE=weather-om-api.service
# The API snapshot root contains immutable model coverages, while the stable
# host DEM source is preseeded below the point-data root. The systemd installer
# maps this deployment setting to the Rust API's OM_DEM_ROOT environment.
WEATHER_OM_DEM_ROOT=/opt/1panel/apps/weather_forecast_server/data/point

# Isolated official-source ECMWF IFS 0.25 degree engine. This image is built
# from the locked submodule and regional source patch; never reuse the GFS tag.
WEATHER_ECMWF_OPENMETEO_IMAGE=weather-forecast-ecmwf
WEATHER_ECMWF_OPENMETEO_TAG=ifs025-REPLACE_WITH_PRINTED_SOURCE_ID
WEATHER_ECMWF_ROOT=/opt/1panel/apps/weather_forecast_server/data/ecmwf
WEATHER_ECMWF_DOWNLOAD_CONCURRENT=2
WEATHER_ECMWF_ROLLING_LOOKBACK_HOURS=72
WEATHER_ECMWF_MINIMUM_START_FREE_BYTES=12884901888
WEATHER_ECMWF_MINIMUM_RUNTIME_FREE_BYTES=4294967296
WEATHER_ECMWF_CACHE_SIZE=2GB
WEATHER_ECMWF_CACHE_META_SIZE=1MB
WEATHER_ECMWF_API_PORT=18081
WEATHER_OPENMETEO_ECMWF_API_URL=http://127.0.0.1:18081/v1/ecmwf
WEATHER_OPENMETEO_ECMWF_API_HOST=api.open-meteo.com
WEATHER_OPENMETEO_ECMWF_LAYER_MODEL=ecmwf_ifs025
WEATHER_OPENMETEO_ECMWF_LAYER_FRAME_COUNT=121
WEATHER_OPENMETEO_ECMWF_LAYER_CHUNK_SIZE=250
WEATHER_OPENMETEO_ECMWF_LAYER_TIMEOUT=180
WEATHER_ECMWF_REGIONAL_GRID=true
# Two degrees of native-grid storage padding around the public 70-140E, 0-58N
# contract preserve global nearest/land cell selection at every public edge.
WEATHER_ECMWF_STORAGE_LEFT_LON=68
WEATHER_ECMWF_STORAGE_RIGHT_LON=142
WEATHER_ECMWF_STORAGE_BOTTOM_LAT=-2
WEATHER_ECMWF_STORAGE_TOP_LAT=60

# Open-Meteo downloads the original GFS files and writes its own local `.om`
# database. Keep weather-model implementation inside the upstream engine.

DATA_RUN_DIRECTORY=/app/data/data_run/
CACHE_SIZE=10GB
CACHE_META_SIZE=1MB

# GFS uses Open-Meteo's indexed GRIB downloader and crops selected original
# messages to the configured China-region grid before writing local `.om`.
# API, interpolation, weather-code, and derived-variable logic remain upstream.
# GFS publishes hourly forecast steps through 120h and 3-hourly steps from
# 123h through 384h. The producer validates the real schedule instead of
# assuming that every hour exists after 120h.
WEATHER_GFS_MAX_FORECAST_HOUR=384
WEATHER_GFS_LOCAL_UTC_OFFSET_HOURS=8
WEATHER_GFS_MIN_PUBLIC_HOURS=300
WEATHER_OM_PRODUCER_ROOT=/opt/1panel/apps/weather_forecast_server/data/om_producer
# Steady-state immutable coverages (each one already contains five GFS runs).
# Publishers briefly keep the previously served coverage until API reload is
# confirmed, then remove it.
WEATHER_OM_GFS_KEEP_COVERAGES=1
WEATHER_GFS_REQUIRED_SOURCE_RUN_COUNT=5
# Three historical runs are strict f000...f005 windows; the newest two are complete.
WEATHER_GFS_REQUIRED_FULL_RUN_COUNT=2
# Do not retain f006 or mix a previous cycle into the next cycle's f000.
WEATHER_GFS_REQUIRED_HISTORY_FORECAST_HOUR=5
# Used only when repairing the currently published run in place.
WEATHER_OM_GFS_SAME_RUN_COVERAGE_REVISION=three-short-two-full-v1
WEATHER_CAMS_REQUIRED_SOURCE_RUN_COUNT=3
WEATHER_CAMS_MAX_FORECAST_HOUR=120
WEATHER_CAMS_LOCAL_UTC_OFFSET_HOURS=8
# One ECPDS coverage contains the three required complete source runs.
WEATHER_OM_CAMS_KEEP_COVERAGES=1
# Use NOAA/NOMADS server-side bounding-box cropping. The S3 inventory remains
# authoritative, but complete global GRIB messages are never production input.
WEATHER_GFS_DOWNLOAD_MODE=nomads-region
WEATHER_NOMADS_REQUEST_DELAY_SECONDS=10
WEATHER_GFS_DOWNLOAD_CONCURRENT=4
WEATHER_GFS013_SURFACE_VARIABLES=temperature_2m,surface_temperature,cloud_cover,cloud_cover_low,cloud_cover_mid,cloud_cover_high,pressure_msl,relative_humidity_2m,precipitation,wind_v_component_10m,wind_u_component_10m,snow_depth,showers,frozen_precipitation_percent,uv_index,uv_index_clear_sky,boundary_layer_height,shortwave_radiation,latent_heat_flux,sensible_heat_flux,diffuse_radiation,total_column_integrated_water_vapour,soil_temperature_0_to_10cm,soil_temperature_10_to_40cm,soil_temperature_40_to_100cm,soil_temperature_100_to_200cm,soil_moisture_0_to_10cm,soil_moisture_10_to_40cm,soil_moisture_40_to_100cm,soil_moisture_100_to_200cm
WEATHER_GFS025_SURFACE_VARIABLES=pressure_msl,categorical_freezing_rain,temperature_80m,temperature_100m,wind_v_component_80m,wind_u_component_80m,wind_v_component_100m,wind_u_component_100m,wind_gusts_10m,freezing_level_height,cape,lifted_index,convective_inhibition,visibility
WEATHER_GFS_UPPER_LEVELS=1000,975,950,925,900,850,800,750,700,650,600,550,500,450,400,350,300,250,200,150,100,50
WEATHER_GFS_UPPER_LEVEL_VARIABLES=temperature,wind_u_component,wind_v_component,geopotential_height,cloud_cover,relative_humidity,vertical_velocity
WEATHER_GFS_UPPER_LEVEL_DOWNLOAD_CONCURRENT=4
WEATHER_OPENMETEO_HTTP_CACHE_ENABLED=true
WEATHER_OPENMETEO_HTTP_CACHE_DIR=/app/data/http_cache
WEATHER_OPENMETEO_HTTP_CACHE_CLEANUP=true
# Model source ranges are one-pass production inputs. Keep their debug HTTP
# caches disabled so a full horizon cannot temporarily consume the whole disk.
WEATHER_GFS_HTTP_CACHE_ENABLED=false
WEATHER_CAMS_HTTP_CACHE_ENABLED=false
WEATHER_CAMS_GREENHOUSE_HTTP_CACHE_ENABLED=false

# CAMS production download uses ECMWF CAMS FTP/ECPDS. Put real credentials in
# config/singapore.private.env.
WEATHER_CAMS_FTP_USER=
WEATHER_CAMS_FTP_PASSWORD=
WEATHER_CAMS_VARIABLES=pm2_5,pm10,aerosol_optical_depth,dust,carbon_monoxide,nitrogen_dioxide,ozone,sulphur_dioxide
WEATHER_CAMS_FTP_DOWNLOAD_CONCURRENT=8
WEATHER_CAMS_PROBE_FORECAST_HOURS=0,120
# The GFS, CAMS ECPDS, and CAMS ADS scheduler tasks each use only their own
# duplicate-prevention lock. They do not share a global lock and may overlap.
# ECPDS main CAMS and ADS greenhouse data publish to separate immutable
# namespaces, so a queued ADS request never blocks GFS or ECPDS production.
WEATHER_CAMS_COVERAGE_REVISION=main-region-v1

# Open-Meteo's official cams_global_greenhouse_gases product is a separate
# daily 00 UTC ADS dataset. The ADS task never probes ADS
# for a latest run. It reads the latest locally published ECPDS run and maps
# both YYYYMMDD00 and YYYYMMDD12 to the same YYYYMMDD00 ADS target. A submitted
# request remains in that task through remote queueing and download, while later
# ADS ticks skip through the ADS task's own lock. The request is server-cropped
# to the storage bounds exported by the producer.
# The regular ECPDS files have no bbox endpoint and are cropped during import.
# Keep the credential only in singapore.private.env or a host .cdsapirc; never
# commit the real key.
WEATHER_CAMS_ADS_KEY=
WEATHER_CAMS_CDSAPI_RC=/home/ubuntu/.cdsapirc
WEATHER_CAMS_GREENHOUSE_VARIABLES=carbon_monoxide
WEATHER_CAMS_GREENHOUSE_DOWNLOAD_CONCURRENT=1
WEATHER_CAMS_GREENHOUSE_MAX_FORECAST_HOUR=120
# ADS queue state is persisted per source run. A process restart resumes the
# same job ID instead of POSTing a duplicate. Polling once per minute keeps the
# long remote wait low-cost; a timeout also preserves the job for the next run.
WEATHER_CAMS_ADS_POLL_INTERVAL_SECONDS=60
WEATHER_CAMS_ADS_JOB_TIMEOUT_HOURS=168
WEATHER_OM_CAMS_GREENHOUSE_KEEP_COVERAGES=1
WEATHER_CAMS_GREENHOUSE_COVERAGE_REVISION=independent-v1

# Required for Open-Meteo point-output parity on land. The upstream engine reads
# DEM from a project-owned WEATHER_DEM_PRESEED_BASE_URL or already preseeded
# local files.
WEATHER_REQUIRE_DEM_SOURCE=true
WEATHER_DEM_PRESEED_ENABLED=false
WEATHER_DEM_PRESEED_BASE_URL=
WEATHER_DEM_PRESEED_CONCURRENT=4
WEATHER_DEM_REQUIRED_LAT_MIN=0
WEATHER_DEM_REQUIRED_LAT_MAX=58

# China and surrounding-region product bounds. These are product/export bounds;
# Open-Meteo source-grid semantics remain authoritative.
WEATHER_REGION_LEFT_LON=70.0
WEATHER_REGION_RIGHT_LON=140.0
WEATHER_REGION_BOTTOM_LAT=0.0
WEATHER_REGION_TOP_LAT=58.0

# Required validation gates before a deployed build can be called complete.
WEATHER_VALIDATION_HOURS=50
WEATHER_VALIDATION_POINT_GATES=50,100,500
