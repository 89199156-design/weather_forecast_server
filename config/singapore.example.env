# Singapore weather-model node example configuration.
# Copy to the deployment environment and fill private mirror URLs there.

# Open-Meteo GFS runtime data mode.
#
# Use `sync` for point/API parity: it downloads Open-Meteo's processed `.om`
# database from WEATHER_OPENMETEO_SYNC_BASE_URL. Production must point this at
# our owned mirror of the Open-Meteo database layout, not at a closed source or
# ad-hoc GRIB conversion path.
#
# Use `raw` only for source-download debugging or approximate regional products.
# NOAA raw/filter conversion does not exactly match the public Open-Meteo API
# database at coastal/masked grid cells.
WEATHER_GFS_DOWNLOAD_MODE=sync
WEATHER_OPENMETEO_SYNC_BASE_URL=
WEATHER_OPENMETEO_SYNC_PAST_DAYS=2
WEATHER_OPENMETEO_SYNC_CONCURRENT=4
WEATHER_GFS013_SYNC_VARIABLES=
WEATHER_GFS025_SURFACE_SYNC_VARIABLES=

# Raw Open-Meteo GFS downloader base URL overrides. These bases must preserve
# the upstream path layout after the base, for example:
#   ${WEATHER_GFS_NOMADS_BASE_URL}/gfs.YYYYMMDD/HH/atmos/...
WEATHER_GFS_NOMADS_BASE_URL=
WEATHER_GFS_AWS_BASE_URL=
WEATHER_GEFS_NOMADS_BASE_URL=
WEATHER_GEFS_AWS_BASE_URL=
WEATHER_GFS_FILTER_DOWNLOAD=false
WEATHER_GFS_FILTER_0P25_URL=
WEATHER_GFS_FILTER_SFLUX_URL=
WEATHER_GFS_MAX_FORECAST_HOUR=120
WEATHER_GFS_DOWNLOAD_CONCURRENT=4

# CAMS global requires ECMWF CAMS FTP credentials for direct Open-Meteo
# `download-cams cams_global` parity. Leave empty only on nodes that should not
# serve CAMS point output.
WEATHER_CAMS_FTP_USER=
WEATHER_CAMS_FTP_PASSWORD=
WEATHER_CAMS_DOWNLOAD_CONCURRENT=1

# Optional domains retained from Open-Meteo. Leave empty unless these models are
# explicitly used by this deployment.
WEATHER_HRRR_NOMADS_BASE_URL=
WEATHER_HRRR_AWS_BASE_URL=
WEATHER_NAM_NOMADS_BASE_URL=

# Required for Open-Meteo point-output parity on land. Use an owned mirror in
# production; the Open-Meteo public S3 path is useful only for parity validation:
#   https://openmeteo.s3.amazonaws.com/data/
WEATHER_DEM_REMOTE_DATA_DIRECTORY=
WEATHER_REQUIRE_DEM_SOURCE=true

# Initial China and surrounding-region product bounds inherited from the old
# Singapore deployment. These are product/export bounds; Open-Meteo source-grid
# semantics remain authoritative.
WEATHER_REGION_LEFT_LON=70.0
WEATHER_REGION_RIGHT_LON=140.0
WEATHER_REGION_BOTTOM_LAT=0.0
WEATHER_REGION_TOP_LAT=58.0

# Required validation gates before a deployed build can be called complete.
WEATHER_VALIDATION_HOURS=50
WEATHER_VALIDATION_POINT_GATES=50,100,500
