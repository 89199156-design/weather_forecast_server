# Singapore weather-model node example configuration.
# Copy to the deployment environment and fill private authorization values there.

# Open-Meteo runtime image. The scripts default to the current git short hash,
# matching scripts/build_openmeteo_image.sh, and fall back to latest only when
# the repository metadata is unavailable.
WEATHER_OPENMETEO_IMAGE=weather-forecast-openmeteo
WEATHER_OPENMETEO_TAG=

# Open-Meteo downloads the original GFS files and writes its own local `.om`
# database. Keep weather-model implementation inside the upstream engine.

DATA_RUN_DIRECTORY=/app/data/data_run/
CACHE_SIZE=10GB
CACHE_META_SIZE=1MB

# GFS uses Open-Meteo's indexed GRIB downloader and crops selected original
# messages to the configured China-region grid before writing local `.om`.
# API, interpolation, weather-code, and derived-variable logic remain upstream.
WEATHER_GFS_MAX_FORECAST_HOUR=120
WEATHER_GFS_DOWNLOAD_CONCURRENT=4
WEATHER_GFS013_SURFACE_VARIABLES=temperature_2m,cloud_cover,cloud_cover_low,cloud_cover_mid,cloud_cover_high,pressure_msl,relative_humidity_2m,precipitation,wind_v_component_10m,wind_u_component_10m,snow_depth,showers,frozen_precipitation_percent,uv_index,boundary_layer_height,shortwave_radiation,latent_heat_flux
WEATHER_GFS025_SURFACE_VARIABLES=pressure_msl,categorical_freezing_rain,wind_gusts_10m,cape,lifted_index,convective_inhibition,visibility,latent_heat_flux
WEATHER_GFS_UPPER_LEVELS=1000,975,950,925,900,850,800,750,700,650,600,550,500,400,300,200
WEATHER_GFS_UPPER_LEVEL_VARIABLES=temperature,wind_u_component,wind_v_component,geopotential_height,cloud_cover,relative_humidity,vertical_velocity
WEATHER_GFS_UPPER_LEVEL_DOWNLOAD_CONCURRENT=4
WEATHER_OPENMETEO_HTTP_CACHE_ENABLED=true
WEATHER_OPENMETEO_HTTP_CACHE_DIR=/app/data/http_cache
WEATHER_OPENMETEO_HTTP_CACHE_CLEANUP=true

# CAMS production download uses ECMWF CAMS FTP/ECPDS. Put real credentials in
# config/singapore.private.env.
WEATHER_CAMS_FTP_USER=
WEATHER_CAMS_FTP_PASSWORD=
WEATHER_CAMS_VARIABLES=pm2_5,pm10,aerosol_optical_depth,dust,carbon_monoxide,nitrogen_dioxide,ozone,sulphur_dioxide
WEATHER_CAMS_DOWNLOAD_CONCURRENT=1

# Required for Open-Meteo point-output parity on land. The upstream engine reads
# DEM from a project-owned WEATHER_DEM_PRESEED_BASE_URL or already preseeded
# local files.
WEATHER_REQUIRE_DEM_SOURCE=true
WEATHER_DEM_PRESEED_ENABLED=false
WEATHER_DEM_PRESEED_BASE_URL=
WEATHER_DEM_PRESEED_CONCURRENT=4

# China and surrounding-region product bounds. These are product/export bounds;
# Open-Meteo source-grid semantics remain authoritative.
WEATHER_REGION_LEFT_LON=70.0
WEATHER_REGION_RIGHT_LON=140.0
WEATHER_REGION_BOTTOM_LAT=0.0
WEATHER_REGION_TOP_LAT=58.0

# Required validation gates before a deployed build can be called complete.
WEATHER_VALIDATION_HOURS=50
WEATHER_VALIDATION_POINT_GATES=50,100,500
