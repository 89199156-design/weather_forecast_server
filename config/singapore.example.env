# Singapore weather-model node example configuration.
# Copy to the deployment environment and fill private authorization values there.

# Open-Meteo runtime image. The scripts default to the current git short hash,
# matching scripts/build_openmeteo_image.sh, and fall back to latest only when
# the repository metadata is unavailable.
WEATHER_OPENMETEO_IMAGE=weather-forecast-openmeteo
WEATHER_OPENMETEO_TAG=

# Open-Meteo GFS runtime data mode.
#
# Production uses `raw`: Open-Meteo downloads the original GFS files and writes
# its own local `.om` database. This keeps the upstream engine as the only
# weather-model implementation while avoiding dependency on Open-Meteo's
# processed public `.om` bucket.
#
# `sync` remains available only as a manual reference/debug path for reading a
# processed `.om` mirror. Do not use it for the normal Singapore production
# batch unless that mirror is explicitly approved for the deployment.
WEATHER_GFS_DOWNLOAD_MODE=raw
WEATHER_OPENMETEO_SYNC_BASE_URL=
WEATHER_OPENMETEO_SYNC_PAST_DAYS=2
WEATHER_OPENMETEO_SYNC_CONCURRENT=4
WEATHER_GFS013_SYNC_VARIABLES=
WEATHER_GFS025_SURFACE_SYNC_VARIABLES=

# Optional Open-Meteo runtime remote reader. Leave this empty for fully local
# production data. When set, the API can read missing processed `.om` files
# through HTTP range requests, which is useful for manual reference runs but can
# hide local-data gaps.
REMOTE_DATA_DIRECTORY=
REMOTE_DATA_DIRECTORY_MINIMUM_AGE=
CACHE_SIZE=10GB
CACHE_META_SIZE=1MB

# Raw mode uses Open-Meteo's downloader with a China-region NOAA filter for GFS.
# Only the transport URL and parsed grid extent are changed; Open-Meteo
# conversion, reader, interpolation, and weather-code logic remain upstream.
WEATHER_GFS_FILTER_DOWNLOAD=true
WEATHER_GFS_FILTER_SFLUX_URL=https://nomads.ncep.noaa.gov/cgi-bin/filter_gfs_sflux.pl
WEATHER_GFS_FILTER_0P25_URL=https://nomads.ncep.noaa.gov/cgi-bin/filter_gfs_0p25.pl
WEATHER_GFS_FILTER_0P25B_URL=https://nomads.ncep.noaa.gov/cgi-bin/filter_gfs_0p25b.pl
WEATHER_GFS_FILTER_INDEX_BASE_URL=https://noaa-gfs-bdp-pds.s3.amazonaws.com
WEATHER_GFS_MAX_FORECAST_HOUR=120
WEATHER_GFS_DOWNLOAD_CONCURRENT=4
WEATHER_GFS_UPPER_LEVELS=1000,975,950,925,900,850,800,750,700,650,600,550,500,400,300,200
WEATHER_GFS_UPPER_LEVEL_PGRB2_LEVELS=1000,975,950,925,900,850,800,750,700,650,600,550,500,400,300,200
WEATHER_GFS_UPPER_LEVEL_VARIABLES=temperature,wind_u_component,wind_v_component,geopotential_height,cloud_cover,relative_humidity
WEATHER_GFS_UPPER_LEVEL_CHUNK_SIZE=4
WEATHER_GFS_UPPER_LEVEL_DOWNLOAD_CONCURRENT=1
WEATHER_OPENMETEO_HTTP_CACHE_ENABLED=true
WEATHER_OPENMETEO_HTTP_CACHE_DIR=/app/data/http_cache
WEATHER_OPENMETEO_HTTP_CACHE_CLEANUP=true

# CAMS production uses the official ADS area request so only the configured
# China-region subset is downloaded. The Open-Meteo CAMS converter and reader
# stay authoritative after the source response is bounded.
WEATHER_CAMS_AREA_DOWNLOAD=true
WEATHER_CAMS_ADS_KEY=

# Optional fallback for the upstream ECMWF CAMS file server. This downloads
# full global NetCDF inputs and is not the normal bounded production path.
WEATHER_CAMS_FTP_USER=
WEATHER_CAMS_FTP_PASSWORD=
WEATHER_CAMS_DOWNLOAD_CONCURRENT=1

# Required for Open-Meteo point-output parity on land. The upstream engine reads
# DEM through REMOTE_DATA_DIRECTORY, or from local preseeded files. Use the
# upstream Open-Meteo public data URL when permitted:
#   https://openmeteo.s3.amazonaws.com/data/
WEATHER_REQUIRE_DEM_SOURCE=true
WEATHER_DEM_PRESEED_ENABLED=true
WEATHER_DEM_PRESEED_BASE_URL=https://openmeteo.s3.amazonaws.com/data/copernicus_dem90/static
WEATHER_DEM_PRESEED_CONCURRENT=4

# China and surrounding-region product bounds. These are product/export bounds;
# Open-Meteo source-grid semantics remain authoritative.
WEATHER_REGION_LEFT_LON=70.0
WEATHER_REGION_RIGHT_LON=140.0
WEATHER_REGION_BOTTOM_LAT=0.0
WEATHER_REGION_TOP_LAT=58.0

# Required validation gates before a deployed build can be called complete.
WEATHER_VALIDATION_HOURS=50
WEATHER_VALIDATION_POINT_GATES=50,100,500
